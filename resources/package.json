    "react-dom": "^15.6.2",
    "react-intl": "^2.9.0",
    "react-pencil": "^1.0.1",
    "react-redux": "^4.4.10",
    "react-treeview": "^0.4.7",
    "redux": "^3.7.2",
    "redux-promise-middleware": "^3.0.1",
    "redux-thunk": "^2.4.2",
    "uid": "0.0.2",
    "whatwg-fetch": "^1.1.1"
  },
  "engines": {
    "node": ">=18"
