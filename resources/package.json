  "description": "React application to create or edit taxonomies",
  "private": true,
  "main": "src/js/index.js",
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.config.prod.js",
    "lint": "eslint src",
    "start": "node server.js",
    "test": "NODE_ENV=test mocha --require @babel/register --require ./src/test/setup.js --recursive src/test/",
    "test:watch": "NODE_ENV=test pnpm test -- --watch",
    "test:cov": "NODE_ENV=test c8 mocha --require @babel/register --require ./src/test/setup.js --recursive src/test/",
    "prettier": "prettier --single-quote --check 'src/**/*.{js,jsx,ts,tsx,json,css,scss,md}'",
    "prettier:fix": "prettier --single-quote --write 'src/**/*.{js,jsx,ts,tsx,json,css,scss,md}'"
  },
  "author": "Cédric Messiant",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.25.9",
    "@babel/plugin-transform-class-properties": "^7.25.9",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-flow": "^7.29.7",
    "@babel/preset-react": "^7.25.9",
    "@babel/register": "^7.25.9",
    "babel-loader": "^9.2.1",
    "babel-plugin-react-intl": "^2.4.0",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "c8": "^10.1.3",
    "chai": "^3.5.0",
    "chai-equal-jsx": "^1.0.9",
    "chai-spies": "*",
    "cypress": "^4.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "express": "^4.21.2",
    "mocha": "^10.8.2",
    "prettier": "1.19.1",
    "redux-devtools": "^3.7.0",
    "redux-devtools-dock-monitor": "^1.2.0",
    "redux-devtools-log-monitor": "^1.4.0",
    "terser-webpack-plugin": "^5.6.1",
    "webpack": "^5.97.1",
